{
  "expo": {
    "name": "AstraCIT",
    "slug": "AstraCIT",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F172A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sujey.astracit",
      "infoPlist": {
        "NSCameraUsageDescription": "AstraCIT needs camera access to scan institutional asset QR codes for the Auditor Hub."
      }
    },
    "android": {
      "package": "com.sujey.astracit",
      "versionCode": 2,
      "adaptiveIcon": {
        "backgroundColor": "#0F172A",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "permissions": [
        "CAMERA",
        "WRITE_EXTERNAL_STORAGE",
        "READ_EXTERNAL_STORAGE",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "CAMERA",
        "WRITE_EXTERNAL_STORAGE",
        "READ_EXTERNAL_STORAGE",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow AstraCIT to access your camera to verify institutional assets.",
          "microphonePermission": "Allow AstraCIT to access your microphone."
        }
      ],
      "expo-sharing"
    ],
    "extra": {
      "eas": {
        "projectId": "4f543d41-60c6-4cb4-986e-f86af8efe62c"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/4f543d41-60c6-4cb4-986e-f86af8efe62c"
    }
  }
}
