{
  "expo": {
    "name": "AstraCIT",
    "slug": "astracit",
    "version": "1.0.3",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F172A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sujey.astracit",
      "infoPlist": {
        "NSCameraUsageDescription": "AstraCIT needs camera access to scan institutional asset QR codes for the Auditor Hub."
      }
    },
    "android": {
      "package": "com.sujey.astracit",
      "versionCode": 3,
      "adaptiveIcon": {
        "backgroundColor": "#0F172A",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "permissions": [
        "CAMERA",
        "WRITE_EXTERNAL_STORAGE",
        "READ_EXTERNAL_STORAGE",
        "RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow AstraCIT to access your camera to verify institutional assets.",
          "microphonePermission": "Allow AstraCIT to access your microphone."
        }
      ],
      "expo-sharing"
    ],
    "extra": {
      "eas": {
        "projectId": "d5c40b52-0c14-41cb-ae35-b305bd2dc060"
      }
    },
    "owner": "hackhive"
  }
}